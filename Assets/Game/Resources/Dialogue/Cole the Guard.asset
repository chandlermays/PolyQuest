  m_rect:
    serializedVersion: 2
    x: 250
    y: 1100
    width: 200
    height: 100
  m_text: Just checking in.
  m_isPlayerSpeaking: 1
  m_children:
  - 389a64df-5386-42d8-b022-264d2b387a3e
  m_onEnterEvents: []
  m_onExitEvents: []
