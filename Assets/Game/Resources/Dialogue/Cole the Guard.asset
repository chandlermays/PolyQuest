  m_rect:
    serializedVersion: 2
    x: 750
    y: 250
    width: 200
    height: 100
  m_text: Order of the Anvil?
  m_isPlayerSpeaking: 1
  m_children:
  - 17e039b1-b65c-464f-a297-4c99d9bfe0c7
  m_onEnterEvents: []
  m_onExitEvents: []
