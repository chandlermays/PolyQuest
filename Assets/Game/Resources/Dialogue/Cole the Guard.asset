  m_rect:
    serializedVersion: 2
    x: 250
    y: 1101
    width: 200
    height: 100
  m_text: Just checking in.
  m_isPlayerSpeaking: 1
  m_children:
  - 389a64df-5386-42d8-b022-264d2b387a3e
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-1582755868554617953
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: e8303ed2-706d-4371-9717-8104d713df8a
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 750
    y: 650
    width: 200
    height: 100
  m_text: I don't know how to thank you. This... this means everything to me.
  m_isPlayerSpeaking: 0
  m_children:
  - 6af103ed-416b-4d19-b906-f2b08db5e503
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-1149968562205888997
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: e9222841-0d50-4d3b-bd76-b8ccdcfbfe83
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 800
    width: 200
    height: 100
  m_text: He was a guard, like me. Worked the northern road for 40 years. Never missed
    a shift.
  m_isPlayerSpeaking: 0
  m_children:
  - c921e5b4-525a-4bbf-8720-9a6019ae8b5b
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-874512062930708413
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
