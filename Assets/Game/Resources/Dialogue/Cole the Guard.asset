  m_rect:
    serializedVersion: 2
    x: 500
    y: 150
    width: 200
    height: 100
  m_text: I know it sounds foolish, but.. it matters to me.
  m_isPlayerSpeaking: 0
  m_children:
  - 5e5da907-7179-47e1-9513-9d657cfbd7ea
  - 11db6863-cfe7-4f2e-9200-d0bc3c71ab2f
