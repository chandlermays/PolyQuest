  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 450
    width: 200
    height: 100
  m_text: Northeast of town, near the watchtower. Somewhere along the patrol path.
  m_isPlayerSpeaking: 0
  m_children:
  - 2b6c38b0-7af4-4835-9d5c-e37a8f22055a
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
