  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 1111dd19-13e8-476b-9c9b-4261baad4acb
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1500
    y: 650
    width: 200
    height: 100
  m_text: Please, take this. It may not be worth much now... but I'd like you to
    have it.
  m_isPlayerSpeaking: 0
  m_children: []
  m_onEnterEvents: []
  m_onExitEvents:
  - {fileID: 11400000, guid: abd41e4c82bd0d9408d37bf29e1365b0, type: 2}
