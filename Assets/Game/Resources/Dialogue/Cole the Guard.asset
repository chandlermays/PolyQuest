--- !u!114 &-9027272995924290315
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 9439aa64-09e4-47e8-8b76-27683f6a6c8a
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1500
    y: 250
    width: 200
    height: 100
  m_text: "They\u2019re gone now\u2026 but I always wanted to be like them."
  m_isPlayerSpeaking: 0
  m_children:
  - 5e5da907-7179-47e1-9513-9d657cfbd7ea
  - 11db6863-cfe7-4f2e-9200-d0bc3c71ab2f
