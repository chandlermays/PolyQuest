  m_rect:
    serializedVersion: 2
    x: 1250
    y: 550
    width: 200
    height: 100
  m_text: Then I went and lost it like a fool.
  m_isPlayerSpeaking: 0
  m_children:
  - 4990062c-243b-42c7-82e1-8762148cd4ba
  - 9a60b90c-97c0-4572-a084-1cdda018d73b
