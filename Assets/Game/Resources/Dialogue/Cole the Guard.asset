  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1000
    y: 550
    width: 200
    height: 100
  m_text: Made me promise I'd carry it with honor.
  m_isPlayerSpeaking: 0
  m_children:
  - 0f6dd875-b7ac-423d-b725-91d1b75f5966
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-3265541250291459716
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
