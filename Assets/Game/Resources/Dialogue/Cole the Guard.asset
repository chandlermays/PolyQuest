MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 35d19188-8dc2-4d8e-bfe7-562f597d6d72
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1500
    y: 150
    width: 200
    height: 100
  m_text: Sounds like a lot of work for just an old sword.
  m_isPlayerSpeaking: 1
  m_children:
  - 969c780a-57a1-4b8c-99b0-1b981b392a93
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
