  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1750
    y: 150
    width: 200
    height: 100
  m_text: Well... it's all I have left of him. My granfather raised me. Told me stories
    about the Order, about serving something bigger than yourself.
  m_isPlayerSpeaking: 0
  m_children:
  - eebb6e1a-d269-4435-ba84-30170b8f1d82
  m_onEnterEvents: []
  m_onExitEvents: []
