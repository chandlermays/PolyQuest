  m_Name: e9222841-0d50-4d3b-bd76-b8ccdcfbfe83
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 800
    width: 200
    height: 100
  m_text: He was a guard, same as me. Worked the northern road forty years and never
    missed a shift.
  m_isPlayerSpeaking: 0
  m_children:
  - c921e5b4-525a-4bbf-8720-9a6019ae8b5b
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
