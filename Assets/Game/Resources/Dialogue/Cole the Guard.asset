  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1250
    y: 50
    width: 200
    height: 100
  m_text: But my grandfather said honest steel doesn't need to shine.
  m_isPlayerSpeaking: 0
  m_children:
  - 2a78fe35-0a29-4046-a117-9de1f3970770
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-3652557891886088997
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
