  m_rect:
    serializedVersion: 2
    x: 0
    y: 952
    width: 200
    height: 100
  m_text: Oh, hey traveler! Thanks again for finding my family's sword.
  m_isPlayerSpeaking: 0
  m_children:
  - 66c4b8c1-4335-4f71-ad9a-5240150ea292
  - 147b359d-5122-4b4d-8693-0d22f69021c8
