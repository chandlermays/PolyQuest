  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1000
    y: 650
    width: 200
    height: 100
  m_text: My grandfather used to tell me, "The Anvil favors those who act without
    expecting reward."
  m_isPlayerSpeaking: 0
  m_children:
  - c1b8ae38-8a59-47ca-a8b1-61ff9ec91ce9
