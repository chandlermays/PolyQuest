  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1251
    y: 150
    width: 200
    height: 100
  m_text: By the time I realized, it was gone.
  m_isPlayerSpeaking: 0
  m_children:
  - 88dd4ef9-50bb-40de-9450-21bffa24ea2a
  - 35d19188-8dc2-4d8e-bfe7-562f597d6d72
  - 71743691-6a0e-4f18-b787-39163066607d
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-8891349124880596695
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 19ca39f0-2ab9-4d1d-9697-0726eaeb509c
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1250
    y: 250
    width: 200
    height: 100
  m_text: "My grandfather used to say the Order made the world stronger, one tempered
    soul at a time. They\u2019re gone now\u2026 but I always wanted to be like them."
  m_isPlayerSpeaking: 0
  m_children:
  - 5e5da907-7179-47e1-9513-9d657cfbd7ea
  - 11db6863-cfe7-4f2e-9200-d0bc3c71ab2f
  - a2650da3-1d90-4ce9-a0bb-6b100fbb127c
  - 47df7801-0104-44c7-b169-767cadaa760a
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-8079477025271551085
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: a536fc4b-ae63-4e09-8667-b475c632ca6f
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 650
    width: 200
    height: 100
  m_text: Oh! That's it! My family's sword!
  m_isPlayerSpeaking: 0
  m_children:
  - e8303ed2-706d-4371-9717-8104d713df8a
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-7482323237798839356
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 6a34770c-e833-430c-8cf3-f570643fff6e
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 2000
    y: 50
    width: 200
    height: 100
  m_text: Check near the old watchtower north of town. If you find it, please bring
    it back to me.
  m_isPlayerSpeaking: 0
  m_children: []
  m_onEnterEvents: []
  m_onExitEvents:
  - {fileID: 11400000, guid: 7d5f0d0838dcdb24899658df96cc067b, type: 2}
  m_condition:
    m_AND: []
--- !u!114 &-6553455302847918776
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 1ff9d1f8-be84-4d7f-b6dc-ba80902cd43f
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1000
    y: 50
    width: 200
    height: 100
  m_text: Oh it's old. Like, really old. But he told me stories when I was young.
    Probably half of them made up.
  m_isPlayerSpeaking: 0
  m_children:
  - 83428bff-aca0-489e-9eea-a0a24f06684b
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-6189532582545626272
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: ecd91032-d343-4d34-ad8c-dab41d59fdaa
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 0
    y: 150
    width: 200
    height: 100
  m_text: You there! Say, uh.. you haven't seen an old iron sword anywhere, have
    you?
  m_isPlayerSpeaking: 0
  m_children:
  - aaf1f2e2-f930-473b-97a8-622e9831cd6d
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND:
    - m_OR:
      - m_predicate: 2
        m_parameters:
        - A Family Heirloom
        - 
        m_negate: 0
    - m_OR:
      - m_predicate: 4
        m_parameters:
        - A Family Heirloom
        - 
        m_negate: 1
--- !u!114 &-6081266683502774643
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
