  m_rect:
    serializedVersion: 2
    x: 500
    y: 350
    width: 200
    height: 100
  m_text: I appreciate it, truly. Take your time, I'm sure you've got other things
    to do.
  m_isPlayerSpeaking: 0
  m_children: []
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
