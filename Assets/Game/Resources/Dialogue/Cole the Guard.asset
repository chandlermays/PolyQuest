--- !u!114 &1369591639861752485
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 6af103ed-416b-4d19-b906-f2b08db5e503
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1000
    y: 650
    width: 200
    height: 100
  m_text: You know, my grandfather used to say, "The Anvil favors those who act without
    expecting reward." You didn't have to help. But you did.
  m_isPlayerSpeaking: 0
  m_children:
  - 1111dd19-13e8-476b-9c9b-4261baad4acb
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &2106654571636198857
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 474e5233-1cbd-49c1-9157-f61097715ceb
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 451
    width: 200
    height: 100
  m_text: I appreciate it, really. Take your time, I know you've got other things
    to do.
  m_isPlayerSpeaking: 0
  m_children: []
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &2353606858889110313
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 9cdd047c-af7b-4a05-bf62-9cbcc916bb27
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1000
    y: 350
    width: 200
    height: 100
  m_text: Oh. Well, if you happen to come across it, please let me know. It would
    mean the world to me.
  m_isPlayerSpeaking: 0
  m_children: []
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &2546876412126938508
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 88dd4ef9-50bb-40de-9450-21bffa24ea2a
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1500
    y: 50
    width: 200
    height: 100
  m_text: I'll help you look for it.
  m_isPlayerSpeaking: 1
  m_children:
  - d89b7087-1b92-4ef2-b756-e3dfd2f3f0a4
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &2853851121841078154
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: c921e5b4-525a-4bbf-8720-9a6019ae8b5b
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 750
    y: 800
    width: 200
    height: 100
  m_text: He'd tell me stories about the Order, how they'd forge their own weapons,
    swear oaths under the stars.
  m_isPlayerSpeaking: 0
  m_children:
  - 93bf9c69-9634-4904-b633-a3b3216b7150
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &2970248990089083994
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 802cafdc-84a9-49ce-a6f6-753272f4e904
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 1000
    width: 200
    height: 100
  m_text: It's the "Order of the Anvil". They believed that the world was forged
    through trials, like metal on an anvil. Captain Flint used to be one of them,
    you know. Before they disbanded.
  m_isPlayerSpeaking: 0
  m_children:
  - 66c4b8c1-4335-4f71-ad9a-5240150ea292
  - 147b359d-5122-4b4d-8693-0d22f69021c8
  - 34be28b3-fca0-4bda-82fb-528eb56f5113
  - 435d4d5d-dec3-41bc-9826-439394868ae5
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &3937746920629010859
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 75a70f4e-d6a3-4de0-920a-4589f7e5fff0
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 0
    y: 500
    width: 200
    height: 100
  m_text: Any luck finding the sword?
  m_isPlayerSpeaking: 0
  m_children:
  - 9a60b90c-97c0-4572-a084-1cdda018d73b
  - 4990062c-243b-42c7-82e1-8762148cd4ba
