  m_rect:
    serializedVersion: 2
    x: 1000
    y: 50
    width: 200
    height: 100
  m_text: It's nothing fancy. Worn grip, chipped edge, too heavy by modern standards.
  m_isPlayerSpeaking: 0
  m_children:
  - 83428bff-aca0-489e-9eea-a0a24f06684b
  m_onEnterEvents: []
