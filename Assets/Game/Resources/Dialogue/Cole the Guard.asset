--- !u!114 &5419365734795476165
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 6935caae-7b9f-45e6-8399-813886ce5482
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 900
    width: 200
    height: 100
  m_text: I'll carry it. Like he did. I may not be a knight of the Order, but I can
    still live by their ideals. Protect people. Do what's right. That's enough for
    me.
  m_isPlayerSpeaking: 0
  m_children:
  - 66c4b8c1-4335-4f71-ad9a-5240150ea292
  - 147b359d-5122-4b4d-8693-0d22f69021c8
  - 34be28b3-fca0-4bda-82fb-528eb56f5113
  - 435d4d5d-dec3-41bc-9826-439394868ae5
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &5948230494969356170
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: d89b7087-1b92-4ef2-b756-e3dfd2f3f0a4
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1750
    y: 50
    width: 200
    height: 100
  m_text: Really? You'd do that? Thank you! I mean it.
  m_isPlayerSpeaking: 0
  m_children:
  - 6a34770c-e833-430c-8cf3-f570643fff6e
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
