  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 0
    y: 952
    width: 200
    height: 100
  m_text: Oh, hey traveler! Thanks again for finding my family's sword.
  m_isPlayerSpeaking: 0
  m_children:
  - 66c4b8c1-4335-4f71-ad9a-5240150ea292
  - 147b359d-5122-4b4d-8693-0d22f69021c8
  - 34be28b3-fca0-4bda-82fb-528eb56f5113
  - 435d4d5d-dec3-41bc-9826-439394868ae5
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND:
    - m_OR:
      - m_predicate: 4
        m_parameters:
        - A Family Heirloom
        - 
        m_negate: 0
--- !u!114 &-313003426535005053
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: eebb6e1a-d269-4435-ba84-30170b8f1d82
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 2000
    y: 150
    width: 200
    height: 100
  m_text: That sword was proof it wasn't all just tales. Without it, I feel like
    I've lost him all over again.
  m_isPlayerSpeaking: 0
  m_children:
  - 88dd4ef9-50bb-40de-9450-21bffa24ea2a
  - 35d19188-8dc2-4d8e-bfe7-562f597d6d72
  - 71743691-6a0e-4f18-b787-39163066607d
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
