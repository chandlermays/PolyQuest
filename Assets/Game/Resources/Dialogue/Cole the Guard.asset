    serializedVersion: 2
    x: 750
    y: 550
    width: 200
    height: 100
  m_text: He said one day it would be mine.
  m_isPlayerSpeaking: 0
  m_children:
  - 21e4b266-1e36-4ea4-a56f-4babd895ef28
  m_onEnterEvents: []
