  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 250
    y: 800
    width: 200
    height: 100
  m_text: Tell me more about your grandfather.
  m_isPlayerSpeaking: 1
  m_children:
  - e9222841-0d50-4d3b-bd76-b8ccdcfbfe83
  m_onEnterEvents: []
  m_onExitEvents: []
