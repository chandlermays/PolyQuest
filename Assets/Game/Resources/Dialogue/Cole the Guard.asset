  m_rect:
    serializedVersion: 2
    x: 500
    y: 650
    width: 200
    height: 100
  m_text: ...That's it! My family's sword!
  m_isPlayerSpeaking: 0
  m_children:
  - e8303ed2-706d-4371-9717-8104d713df8a
  m_onEnterEvents: []
  m_onExitEvents: []
