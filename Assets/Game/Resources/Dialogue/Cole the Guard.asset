  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 750
    y: 1000
    width: 200
    height: 100
  m_text: Captain Flint used to serve with them, you know.
  m_isPlayerSpeaking: 0
  m_children:
  - ae796f5e-d02e-4fa5-b043-e825b153929f
  m_onEnterEvents: []
  m_onExitEvents: []
