  m_rect:
    serializedVersion: 2
    x: 750
    y: 50
    width: 200
    height: 100
  m_text: Tell me about this sword.
  m_isPlayerSpeaking: 1
  m_children:
  - 1ff9d1f8-be84-4d7f-b6dc-ba80902cd43f
  m_onEnterEvents: []
  m_onExitEvents: []
