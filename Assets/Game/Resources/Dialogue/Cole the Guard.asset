  m_Name: c1b8ae38-8a59-47ca-a8b1-61ff9ec91ce9
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1250
    y: 650
    width: 200
    height: 100
  m_text: You didn't have to help. But you did.
  m_isPlayerSpeaking: 0
  m_children:
  - 1111dd19-13e8-476b-9c9b-4261baad4acb
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
