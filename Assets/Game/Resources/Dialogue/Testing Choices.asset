    x: 800
    y: 450
    width: 200
    height: 100
  m_text: Stonewick's a hard town full of harder people. We quarry stone, we cut
    timber, we keep our roofs from collapsing--mostly.
  m_isPlayerSpeaking: 0
  m_children:
  - f2dba861-1db9-4a41-a8b7-771e22842981
  m_onEnterEvents: []
