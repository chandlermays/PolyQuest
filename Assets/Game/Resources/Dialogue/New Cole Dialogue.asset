  m_Name: 47df7801-0104-44c7-b169-767cadaa760a
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 750
    y: 350
    width: 200
    height: 100
  m_text: Sorry, I haven't seen it.
  m_isPlayerSpeaking: 1
  m_children:
  - 9cdd047c-af7b-4a05-bf62-9cbcc916bb27
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-4973363408616697254
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: aaf1f2e2-f930-473b-97a8-622e9831cd6d
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 250
    y: 150
    width: 200
    height: 100
  m_text: Not just any sword, it's been in my family for generations. My grandfather
    carried it when he served with the Order of the Anvil! Or, so he claimed, anyway.
  m_isPlayerSpeaking: 0
  m_children:
  - 994c188e-4d29-4b38-b08b-c27c6b42847b
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &-4965687540043012042
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 17e039b1-b65c-464f-a297-4c99d9bfe0c7
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1000
    y: 250
    width: 200
    height: 100
  m_text: 'They were knights. Real ones. They protected the land, lived by a code:
    honor, sacrifice, all of it.'
  m_isPlayerSpeaking: 0
  m_children:
  - 19ca39f0-2ab9-4d1d-9697-0726eaeb509c
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
