--- !u!114 &6142969160763919591
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 5fbabb5d-9572-4688-bbe5-046c89c0a4dd
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1750
    y: 250
    width: 200
    height: 100
  m_text: Sounds risky, what's in it for me?
  m_isPlayerSpeaking: 1
  m_children:
  - 082db796-3820-44c4-91e8-0914ed7bd881
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &6196048715864234325
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: c88fa8ca-4548-4205-8702-972a353d1da8
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1250
    y: 200
    width: 200
    height: 100
  m_text: There's a camp somewhere east of town. Find it. Break it.
  m_isPlayerSpeaking: 0
  m_children:
  - 9d4aa57d-f944-4f3e-bff1-4e6265577891
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &6785081378266468767
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 4a121fc4-ed15-4fb4-a02e-dc8904bc7a5e
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1250
    y: 50
    width: 200
    height: 100
  m_text: These ones are organized. Better armed than they've any right to be.
  m_isPlayerSpeaking: 0
  m_children:
  - 4997ca4c-90f0-4aa9-83e8-3714ecfcca38
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
