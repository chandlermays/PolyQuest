  m_rect:
    serializedVersion: 2
    x: 1750
    y: 150
    width: 200
    height: 100
  m_text: I'll take care of it.
  m_isPlayerSpeaking: 1
  m_children:
  - 9af8452c-f39d-4536-9a06-63aa4c87008d
  m_onEnterEvents: []
  m_onExitEvents: []
