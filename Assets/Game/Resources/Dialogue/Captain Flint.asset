  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: 33b95e86-7ecf-4620-bbbb-ae4b5f694392
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 750
    y: 900
    width: 200
    height: 100
  m_text: This is what I feared.
  m_isPlayerSpeaking: 0
  m_children:
  - ad711fa2-59b3-44fe-947c-8b721a5a94df
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
--- !u!114 &3606557143491732333
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2f8ddea4018d2fd4fb68f1940165454c, type: 3}
  m_Name: f2dba861-1db9-4a41-a8b7-771e22842981
  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1250
    y: 400
    width: 200
    height: 100
  m_text: Folks here ask little. Honest work. Quiet nights. Lately, they'd have less
    of both.
  m_isPlayerSpeaking: 0
  m_children:
  - 955c7c61-ab73-453b-8d80-51af8b42a43e
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
