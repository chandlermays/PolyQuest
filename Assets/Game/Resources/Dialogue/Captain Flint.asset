  m_rect:
    serializedVersion: 2
    x: 2000
    y: 250
    width: 200
    height: 100
  m_text: Fair pay. And Stonewick's trust. That reaches farther than gold, if you're
    wise enough to know it.
  m_isPlayerSpeaking: 0
  m_children:
  - b56e4102-d3dd-41a3-8bad-1227b296ea79
  - 8ab5243f-2596-4862-8691-21aba540e55b
