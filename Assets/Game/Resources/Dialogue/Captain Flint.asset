  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 500
    y: 1000
    width: 200
    height: 100
  m_text: Something about that doesn't sit right with me. But I guess they must've
    just gotten lucky.
  m_isPlayerSpeaking: 0
  m_children:
  - a60340a8-2a50-4bde-b835-f6c4dac6e2a3
  m_onEnterEvents: []
  m_onExitEvents: []
