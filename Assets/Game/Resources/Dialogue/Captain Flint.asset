  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 750
    y: 400
    width: 200
    height: 100
  m_text: Tell me about Stonewick.
  m_isPlayerSpeaking: 1
  m_children:
  - d33c445e-2ee4-4954-a8b0-0debe3c66693
  m_onEnterEvents: []
  m_onExitEvents: []
