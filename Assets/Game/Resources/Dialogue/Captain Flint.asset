  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 1500
    y: 400
    width: 200
    height: 100
  m_text: Still, people here look after each other. That matters.
  m_isPlayerSpeaking: 0
