  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 2000
    y: 350
    width: 200
    height: 100
  m_text: Then we're finished here.
  m_isPlayerSpeaking: 0
  m_children:
  - 95c078e0-90f7-428d-9f9a-1467c98a79be
  m_onEnterEvents: []
  m_onExitEvents: []
  m_condition:
    m_AND: []
