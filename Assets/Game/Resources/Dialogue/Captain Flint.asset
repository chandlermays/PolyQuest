  m_EditorClassIdentifier: Assembly-CSharp::PolyQuest.Dialogues.DialogueNode
  m_rect:
    serializedVersion: 2
    x: 0
    y: 300
    width: 200
    height: 100
  m_text: Welcome to Stonewick, traveler.
  m_isPlayerSpeaking: 0
  m_children:
  - 556967a1-7d80-4ef1-a222-8226776a5044
  m_onEnterEvents: []
  m_onExitEvents: []
